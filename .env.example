# ============================================================
# ossx 环境变量模板
# 复制为 .env 后填入实际值
# .env 文件已在 .gitignore 中排除，禁止提交
#
# 密钥命名约定：前缀 FOUNDATIONX_OSSX_
# ============================================================

# ---- S3 / 对象存储端点 ----
FOUNDATIONX_OSSX_ENDPOINT=127.0.0.1:9000
FOUNDATIONX_OSSX_ACCESS_KEY=
FOUNDATIONX_OSSX_SECRET_KEY=
FOUNDATIONX_OSSX_BUCKET=dev-ossx
FOUNDATIONX_OSSX_REGION=us-east-1
FOUNDATIONX_OSSX_USE_SSL=false
