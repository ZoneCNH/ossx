# ============================================================
# ossx 环境变量模板
# 复制为 .env 后填入实际值（.env 已在 .gitignore 中排除）
#
# Aliyun OSS 对象存储 L2 adapter — 真实 OSS 集成由环境变量注入
# S3/MinIO/Azure/GCS Provider 仅保留扩展位
# ============================================================

# ---- 集成测试开关 ----
# 设为 1 启用真实 Aliyun OSS 集成测试（默认跳过）
OSSX_INTEGRATION=0

# ---- OSS 连接参数（OSSX_INTEGRATION=1 时全部必需）----
# OSS Endpoint（例：oss-cn-hangzhou.aliyuncs.com）
OSSX_ENDPOINT=
# OSS Region
OSSX_REGION=cn-hangzhou
# Bucket 名称
OSSX_BUCKET=
# AccessKey ID
OSSX_ACCESS_KEY_ID=
# Secret AccessKey
OSSX_SECRET_ACCESS_KEY=
